#!/usr/bin/env bash
set -euo pipefail

echo "Format: Ruby"
bin/rubocop -A

echo
echo "Format: ERB"
mapfile -d '' erb_files < <(find app/views -name "*.html.erb" -print0)

if ((${#erb_files[@]})); then
  bundle exec erb-format "${erb_files[@]}" --write
fi

echo
echo "Autocorrect: ERB lint"
bundle exec erb_lint --lint-all -a
