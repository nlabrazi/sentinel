# Required in production.
# Generate with: bin/rails secret
SECRET_KEY_BASE=
RAILS_LOG_LEVEL=info

# Database
POSTGRES_HOST=sentinel-db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Active Storage
# local: files are stored in ./storage
# cloudinary: files are stored outside Docker and survive local volume resets
ACTIVE_STORAGE_SERVICE=local
CLOUDINARY_URL=
CLOUDINARY_FOLDER=sentinel/development

# ApiFlash
# Used only when a screenshot is generated or explicitly refreshed.
APIFLASH_ACCESS_KEY=

# Grafana
# Global Grafana settings used to build private authenticated embed URLs.
# Do not put project filters, tokens, snapshots, or public share URLs here.
GRAFANA_BASE_URL=
GRAFANA_DASHBOARD_UID=
GRAFANA_DASHBOARD_SLUG=applications-overview
GRAFANA_VARIABLE_NAME=app
GRAFANA_DEFAULT_THEME=dark
GRAFANA_ORG_ID=1
GRAFANA_DEFAULT_FROM=now-6h
GRAFANA_DEFAULT_TO=now
GRAFANA_GLOBAL_VARIABLE_VALUE=All

# GitHub
GITHUB_TOKEN=

# VPS / SSH
VPS_HOST=
VPS_USER=control-panel
SSH_KEY_PATH=/app/config/ssh_key/id_rsa
SSH_KNOWN_HOSTS_PATH=/app/config/ssh_key/known_hosts
SSH_CONNECT_TIMEOUT_SECONDS=10
SSH_COMMAND_TIMEOUT_SECONDS=600

# Seeded admin user
ADMIN_USERNAME=admin
ADMIN_EMAIL=
ADMIN_PASSWORD=
