# Required in production.
# Generate with: bin/rails secret
SECRET_KEY_BASE=
RAILS_LOG_LEVEL=info

# Database
DATABASE_URL=postgres://postgres:postgres@sentinel-db:5432/sentinel_development

# Active Storage
# local: files are stored in ./storage
# cloudinary: files are stored outside Docker and survive local volume resets
ACTIVE_STORAGE_SERVICE=local
CLOUDINARY_URL=
CLOUDINARY_FOLDER=sentinel/development

# ApiFlash
# Used only when a screenshot is generated or explicitly refreshed.
APIFLASH_ACCESS_KEY=

# GitHub
GITHUB_TOKEN=

# VPS / SSH
VPS_HOST=
VPS_USER=control-panel
SSH_KEY_PATH=/root/.ssh/id_rsa

# Seeded admin user
ADMIN_EMAIL=
ADMIN_PASSWORD=
