<% variant ||= :secondary %>
<% size ||= :md %>
<% icon ||= nil %>
<% label ||= nil %>
<% href ||= nil %>
<% data ||= {} %>
<% html_class ||= "" %>
<% target ||= nil %>
<% rel ||= nil %>
<% title ||= nil %>
<% aria ||= {} %>

<% base_classes =
  "inline-flex items-center justify-center gap-2 rounded-md font-semibold transition focus:outline-none focus:ring-1 disabled:cursor-not-allowed disabled:opacity-60"

variant_classes = {
  primary: "bg-cyan-300 text-gray-950 hover:bg-cyan-200 focus:ring-cyan-300",
  secondary:
    "border border-gray-300 text-gray-700 hover:border-gray-400 hover:bg-gray-100 focus:ring-gray-400 dark:border-gray-700 dark:text-gray-200 dark:hover:border-gray-500 dark:hover:bg-gray-800 dark:focus:ring-gray-600",
  ghost:
    "text-gray-600 hover:bg-gray-100 hover:text-gray-900 focus:ring-gray-400 dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-100 dark:focus:ring-gray-600",
  danger:
    "border border-red-200 bg-red-50 text-red-800 hover:bg-red-100 focus:ring-red-400 dark:border-red-900/60 dark:bg-red-950/40 dark:text-red-200 dark:hover:bg-red-900/50 dark:focus:ring-red-700",
}

size_classes = {
  sm: "px-2.5 py-1.5 text-xs",
  md: "px-4 py-2 text-sm",
  lg: "px-4 py-2.5 text-sm",
}

classes = [
  base_classes,
  variant_classes.fetch(variant.to_sym),
  size_classes.fetch(size.to_sym),
  html_class,
].join(" ") %>

<% if href.present? %>
  <%= link_to href, class: classes, data: data, target: target, rel: rel, title: title, aria: aria do %>
    <%= fa_icon(icon, class_name: "h-4 w-4") if icon.present? %>
    <%= label %>
  <% end %>
<% else %>
  <%= button_tag type: "button", class: classes, data: data, title: title, aria: aria do %>
    <%= fa_icon(icon, class_name: "h-4 w-4") if icon.present? %>
    <%= label %>
  <% end %>
<% end %>
