<% label ||= "" %>
<% value ||= nil %>
<% helper ||= nil %>
<% icon ||= nil %>
<% tone ||= :neutral %>
<% html_class ||= "" %>

<%
  tone_classes = {
    success: "text-green-300",
    warning: "text-yellow-300",
    danger: "text-red-300",
    info: "text-cyan-300",
    neutral: "text-gray-100",
    muted: "text-gray-300"
  }

  value_classes = tone_classes.fetch(tone.to_sym)

  classes = [
    "rounded-lg border border-gray-800 bg-gray-950/70 px-4 py-3",
    html_class
  ].join(" ")
%>

<div class="<%= classes %>">
  <div class="flex items-center gap-2 text-xs font-medium text-gray-500">
    <%= fa_icon(icon, class_name: "text-xs") if icon.present? %>
    <span><%= label %></span>
  </div>

  <p class="mt-2 font-semibold <%= value_classes %>">
    <%= value %>
  </p>

  <% if helper.present? %>
    <p class="mt-1 text-xs text-gray-500">
      <%= helper %>
    </p>
  <% end %>
</div>
