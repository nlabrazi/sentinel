<% label ||= "" %>
<% value ||= nil %>
<% helper ||= nil %>
<% icon ||= nil %>
<% tone ||= :neutral %>
<% html_class ||= "" %>

<% tone_classes = {
  success: "text-green-700 dark:text-green-300",
  warning: "text-yellow-700 dark:text-yellow-300",
  danger: "text-red-700 dark:text-red-300",
  info: "text-cyan-700 dark:text-cyan-300",
  neutral: "text-gray-900 dark:text-gray-100",
  muted: "text-gray-600 dark:text-gray-300",
}

value_classes = tone_classes.fetch(tone.to_sym)

classes = [
  "rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 dark:border-gray-800 dark:bg-gray-950/70",
  html_class,
].join(" ") %>

<div class="<%= classes %>">
  <div class="flex items-center gap-2 text-xs font-medium text-gray-500">
    <%= fa_icon(icon, class_name: "text-xs") if icon.present? %>
    <span><%= label %></span>
  </div>

  <p class="mt-2 font-semibold <%= value_classes %>">
    <%= value %>
  </p>

  <% if helper.present? %>
    <p class="mt-1 text-xs text-gray-500">
      <%= helper %>
    </p>
  <% end %>
</div>
