<section class="mx-auto max-w-7xl">
  <div class="rounded-lg border border-gray-800 bg-gray-900 shadow">
    <div class="space-y-4 border-b border-gray-800 px-4 py-5 sm:px-6">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div class="min-w-0 flex-1">
          <%= form_with url: root_path, method: :get, class: "relative max-w-md", data: { turbo_frame: "_top" } do |form| %>
            <%= fa_icon(:magnifying_glass, class_name: "absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-400") %>
            <%= form.search_field :q, value: @project_search, placeholder: "Search projects", class: "w-full rounded-md border border-gray-600 bg-gray-950 px-10 py-2.5 text-sm text-gray-100 placeholder:text-gray-400 focus:border-cyan-400 focus:outline-none focus:ring-1 focus:ring-cyan-400" %>
          <% end %>
        </div>

        <div class="grid grid-cols-2 gap-3 text-sm sm:grid-cols-5 lg:min-w-[40rem]">
          <div class="rounded-md border border-gray-800 bg-gray-950 px-3 py-2">
            <p class="text-xs text-gray-500">Projects</p>
            <p class="mt-1 font-semibold text-gray-100"><%= @projects.size %></p>
          </div>
          <div class="rounded-md border border-gray-800 bg-gray-950 px-3 py-2">
            <p class="text-xs text-gray-500">Online</p>
            <p class="mt-1 font-semibold text-green-300"><%= @projects.count(&:online?) %></p>
          </div>
          <div class="rounded-md border border-gray-800 bg-gray-950 px-3 py-2">
            <p class="text-xs text-gray-500">Behind</p>
            <p class="mt-1 font-semibold text-yellow-300"><%= @projects.count { |project| project.commits_behind.to_i.positive? } %></p>
          </div>
          <div class="rounded-md border border-gray-800 bg-gray-950 px-3 py-2">
            <p class="text-xs text-gray-500">Open PRs</p>
            <p class="mt-1 font-semibold text-cyan-300"><%= @projects.sum(&:open_pull_requests_count) %></p>
          </div>
          <div class="rounded-md border border-gray-800 bg-gray-950 px-3 py-2">
            <p class="text-xs text-gray-500">Maintenance</p>
            <p class="mt-1 font-semibold text-gray-100"><%= @projects.count(&:maintenance_mode?) %></p>
          </div>
        </div>
      </div>
    </div>

    <div class="divide-y divide-gray-800">
      <% if @projects.any? %>
        <% @projects.each do |project| %>
          <% latest_deployment = @latest_deployments_by_project_id[project.id] %>
          <% running_deployment = @running_deployments_by_project_id[project.id] %>
          <% latest_ping = @latest_pings_by_project_id[project.id] %>
          <% cron_status = project.cron_summary_status %>
          <article class="grid grid-cols-1 gap-4 px-4 py-6 transition hover:bg-gray-800/40 sm:px-6 xl:grid-cols-[8rem_minmax(0,1.25fr)_minmax(28rem,1fr)_12rem] xl:items-center">
            <div class="overflow-hidden rounded border border-gray-800 bg-gray-950">
              <% if @screenshots_enabled && project.screenshot.attached? %>
                <img src="<%= url_for(project.screenshot) %>"
                     alt="Aperçu de <%= project.name %>"
                     class="aspect-video w-full object-cover"
                     loading="lazy">
              <% else %>
                <div class="flex aspect-video w-full items-center justify-center text-xs text-gray-500">No preview</div>
              <% end %>
            </div>

            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2">
                <%= link_to project.name, project_path(project), class: "break-words text-base font-semibold text-gray-100 hover:underline" %>
                <span class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-xs font-semibold <%= project.online? ? 'bg-green-900/40 text-green-300' : project.offline? ? 'bg-red-900/40 text-red-300' : 'bg-gray-800 text-gray-300' %>">
                  <span class="h-1.5 w-1.5 rounded-full <%= project.online? ? 'bg-green-300' : project.offline? ? 'bg-red-300' : 'bg-gray-400' %>"></span>
                  <%= project.status %>
                </span>
                <% if project.maintenance_mode? %>
                  <span class="rounded-full bg-yellow-900/40 px-2 py-0.5 text-xs font-semibold text-yellow-300">Maintenance</span>
                <% end %>
              </div>
              <p class="mt-1 break-all text-sm text-gray-400"><%= project.production_url %></p>
              <div class="mt-3 flex flex-wrap items-center gap-3 text-xs text-gray-500">
                <span><%= project.github_repo %></span>
                <span><%= project.branch %></span>
                <% if project.github_synced_at %>
                  <span>GitHub synced <%= time_ago_in_words(project.github_synced_at) %> ago</span>
                <% else %>
                  <span>GitHub never synced</span>
                <% end %>
                <% if latest_deployment %>
                  <span>Last deploy <%= time_ago_in_words(latest_deployment.created_at) %> ago</span>
                <% else %>
                  <span>No deploy yet</span>
                <% end %>
                <% if latest_ping %>
                  <span>Runtime checked <%= time_ago_in_words(latest_ping.checked_at || latest_ping.created_at) %> ago</span>
                  <% if latest_ping.http_status %>
                    <span>HTTP <%= latest_ping.http_status %></span>
                  <% end %>
                <% else %>
                  <span>No runtime check yet</span>
                <% end %>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3 text-sm sm:grid-cols-5 xl:grid-cols-5">
              <div>
                <p class="text-xs text-gray-500">Prod</p>
                <p class="mt-1 font-mono font-semibold text-gray-100"><%= project.last_commit_deployed.present? ? project.last_commit_deployed.first(7) : "unknown" %></p>
              </div>
              <div>
                <p class="text-xs text-gray-500"><%= project.branch %></p>
                <p class="mt-1 font-mono font-semibold text-gray-100"><%= project.latest_commit_available.present? ? project.latest_commit_available.first(7) : "unknown" %></p>
              </div>
              <div>
                <p class="text-xs text-gray-500">Behind</p>
                <p class="mt-1 font-semibold <%= project.commits_behind.to_i.positive? ? 'text-yellow-300' : 'text-green-300' %>">
                  <%= project.commits_behind.to_i %> commit<%= "s" unless project.commits_behind.to_i == 1 %>
                </p>
              </div>
              <div>
                <p class="text-xs text-gray-500">Cron</p>
                <p class="mt-1 font-semibold <%= cron_status == 'ok' ? 'text-green-300' : cron_status == 'failed' ? 'text-red-300' : 'text-gray-300' %>">
                  <%= cron_status %>
                </p>
              </div>
              <div>
                <p class="text-xs text-gray-500">PRs</p>
                <p class="mt-1 font-semibold <%= project.open_pull_requests_count.positive? ? 'text-cyan-300' : 'text-gray-300' %>">
                  <%= project.open_pull_requests_count %> open
                </p>
                <p class="mt-0.5 text-xs text-gray-500"><%= project.merged_pull_requests_count %> merged</p>
              </div>
            </div>

            <div class="grid grid-cols-1 gap-2 sm:grid-cols-3 xl:grid-cols-1 xl:justify-end">
              <%= button_to refresh_github_commits_project_path(project),
                    method: :post,
                    class: "inline-flex w-full cursor-pointer items-center justify-center gap-2 rounded border border-gray-700 px-3 py-2 text-sm font-semibold text-gray-200 hover:border-gray-500 hover:bg-gray-800",
                    title: "Synchronise les commits et pull requests GitHub pour ce projet",
                    aria: { label: "Synchroniser GitHub pour #{project.name}" } do %>
                <%= fa_icon(:rotate, class_name: "h-4 w-4") %>
                Sync GitHub
              <% end %>
              <%= button_to refresh_runtime_project_path(project),
                    method: :post,
                    class: "inline-flex w-full cursor-pointer items-center justify-center gap-2 rounded border border-gray-700 px-3 py-2 text-sm font-semibold text-gray-200 hover:border-gray-500 hover:bg-gray-800",
                    title: "Lance un healthcheck HTTP immédiat pour ce projet",
                    aria: { label: "Vérifier le runtime de #{project.name}" } do %>
                <%= fa_icon(:rotate, class_name: "h-4 w-4") %>
                Check status
              <% end %>
              <% if running_deployment %>
                <span class="inline-flex w-full items-center justify-center gap-2 rounded bg-gray-800 px-3 py-2 text-sm font-semibold text-gray-400" title="Un déploiement est déjà en cours">
                  <%= fa_icon(:rotate, class_name: "h-4 w-4") %>
                  Running
                </span>
              <% else %>
                <%= button_to deploy_project_path(project),
                      method: :post,
                      class: "inline-flex w-full cursor-pointer items-center justify-center gap-2 rounded bg-cyan-300 px-3 py-2 text-sm font-bold text-gray-950 hover:bg-cyan-200",
                      title: "Déploie le dernier commit connu de la branche suivie",
                      aria: { label: "Déployer #{project.name}" } do %>
                  <%= fa_icon(:play, class_name: "h-4 w-4") %>
                  Deploy latest
                <% end %>
              <% end %>
              <%= link_to "Open project", project_path(project),
                    class: "inline-flex w-full items-center justify-center rounded border border-gray-700 px-3 py-2 text-sm font-semibold text-gray-200 hover:border-gray-500 hover:bg-gray-800",
                    title: "Ouvre la page détaillée du projet" %>
            </div>
          </article>
        <% end %>
      <% else %>
        <div class="px-6 py-10 text-center text-sm text-gray-400">
          No project matches this search.
        </div>
      <% end %>
    </div>
  </div>
</section>
