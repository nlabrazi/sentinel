<div class="bg-white shadow rounded-lg overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
    <h2 class="text-lg font-semibold">Tous les projets</h2>
    <span class="text-xs text-gray-500">Mis à jour il y a quelques secondes</span>
  </div>

  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Projet</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Statut</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Déploiement</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Retard</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @projects.each do |project| %>
        <tr class="hover:bg-gray-50">
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="flex items-center gap-3">
              <% if ENV['APIFLASH_ACCESS_KEY'].present? %>
                <img src="<%= project.screenshot_url %>"
                    alt="Aperçu de <%= project.name %>"
                    class="w-48 h-27 object-cover rounded border border-gray-200 shadow-sm"
                    loading="lazy">
              <% end %>
              <div>
                <div class="text-sm font-medium text-gray-900">
                  <%= link_to project.name, project_path(project), class: "hover:underline" %>
                </div>
                <div class="text-xs text-gray-500"><%= project.production_url %></div>
              </div>
            </div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= project.online? ? 'bg-green-100 text-green-800' : project.offline? ? 'bg-red-100 text-red-800' : 'bg-gray-100 text-gray-800' %>">
              <%= project.status %>
            </span>
            <% if project.maintenance_mode? %>
              <span class="ml-2 px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800">Maintenance</span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
            <% if project.last_commit_deployed %>
              <code class="text-xs bg-gray-100 px-1 rounded"><%= project.last_commit_deployed.first(7) %></code>
              <span class="text-xs text-gray-400 ml-1"><%= time_ago_in_words(project.deployments.last.created_at) if project.deployments.last %></span>
            <% else %>
              <span class="text-gray-400">—</span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm">
            <% if project.commits_behind.to_i > 0 %>
              <span class="text-orange-600 font-medium"><%= project.commits_behind %> commits</span>
            <% else %>
              <span class="text-green-600">À jour</span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
            <%= button_to "Deploy", deploy_project_path(project), method: :post, class: "inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500", form: { data: { turbo_confirm: "Déployer #{project.name} ?" } } %>
            <%= button_to project.maintenance_mode? ? "Désactiver" : "Maintenance",
                  toggle_maintenance_project_path(project), method: :patch,
                  class: "ml-2 inline-flex items-center px-3 py-1.5 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
