<div class="bg-white shadow rounded-lg overflow-hidden dark:bg-gray-900">
  <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center dark:border-gray-800">
    <h2 class="text-lg font-semibold">Tous les projets</h2>
    <span class="text-xs text-gray-500 dark:text-gray-400"><%= @projects.size %> projet(s)</span>
  </div>

  <div class="hidden overflow-x-auto md:block">
  <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
    <thead class="bg-gray-50 dark:bg-gray-800">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-400">Projet</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-400">Statut</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-400">Déploiement</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-400">Retard</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider dark:text-gray-400">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200 dark:bg-gray-900 dark:divide-gray-800">
      <% @projects.each do |project| %>
        <% latest_deployment = @latest_deployments_by_project_id[project.id] %>
        <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/70">
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="flex items-center gap-3">
              <% if @screenshots_enabled %>
                <% if project.screenshot.attached? %>
                <img src="<%= url_for(project.screenshot) %>"
                    alt="Aperçu de <%= project.name %>"
                    class="w-48 h-27 object-cover rounded border border-gray-200 shadow-sm"
                    loading="lazy">
              <% else %>
                <div class="w-48 h-27 bg-gray-200 dark:bg-gray-800 rounded border border-gray-300 dark:border-gray-700 flex items-center justify-center text-xs text-gray-500">
                  Aucun aperçu
                </div>
              <% end %>
              <% end %>
              <div>
                <div class="text-sm font-medium text-gray-900 dark:text-gray-100">
                  <%= link_to project.name, project_path(project), class: "hover:underline" %>
                </div>
                <div class="text-xs text-gray-500 dark:text-gray-400"><%= project.production_url %></div>
              </div>
            </div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= project.online? ? 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300' : project.offline? ? 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300' : 'bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-300' %>">
              <%= project.status %>
            </span>
            <% if project.maintenance_mode? %>
              <span class="ml-2 px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300">Maintenance</span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
            <% if project.last_commit_deployed %>
              <code class="text-xs bg-gray-100 px-1 rounded dark:bg-gray-800 dark:text-gray-200"><%= project.last_commit_deployed.first(7) %></code>
              <span class="text-xs text-gray-400 ml-1"><%= time_ago_in_words(latest_deployment.created_at) if latest_deployment %></span>
            <% else %>
              <span class="text-gray-400">—</span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm">
            <% if project.commits_behind.to_i > 0 %>
              <span class="text-orange-600 font-medium dark:text-orange-400"><%= project.commits_behind %> commits</span>
            <% else %>
              <span class="text-green-600 dark:text-green-400">À jour</span>
            <% end %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
            <%= button_to deploy_project_path(project), method: :post, class: "inline-flex items-center gap-1.5 px-3 py-1.5 border border-transparent text-xs font-medium rounded shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500", form: { data: { turbo_confirm: "Déployer #{project.name} ?" } } do %>
              <%= fa_icon(:play, class_name: "h-3 w-3") %>
              Deploy
            <% end %>
            <%= button_to toggle_maintenance_project_path(project), method: :patch,
                  class: "ml-2 inline-flex items-center gap-1.5 px-3 py-1.5 border border-gray-300 text-xs font-medium rounded text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-200 dark:hover:bg-gray-800" do %>
              <%= fa_icon(:wrench, class_name: "h-3 w-3") %>
              <%= project.maintenance_mode? ? "Désactiver" : "Maintenance" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>

  <div class="divide-y divide-gray-200 dark:divide-gray-800 md:hidden">
    <% @projects.each do |project| %>
      <% latest_deployment = @latest_deployments_by_project_id[project.id] %>
      <article class="space-y-4 px-4 py-5">
        <% if @screenshots_enabled %>
          <% if project.screenshot.attached? %>
            <img src="<%= url_for(project.screenshot) %>"
                 alt="Aperçu de <%= project.name %>"
                 class="aspect-video w-full rounded border border-gray-200 object-cover shadow-sm dark:border-gray-700"
                 loading="lazy">
          <% else %>
            <div class="flex aspect-video w-full items-center justify-center rounded border border-gray-300 bg-gray-200 text-xs text-gray-500 dark:border-gray-700 dark:bg-gray-800">
              Aucun aperçu
            </div>
          <% end %>
        <% end %>

        <div class="min-w-0">
          <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100">
            <%= link_to project.name, project_path(project), class: "hover:underline" %>
          </h3>
          <p class="mt-1 break-all text-xs text-gray-500 dark:text-gray-400"><%= project.production_url %></p>
        </div>

        <div class="grid grid-cols-2 gap-3 text-sm">
          <div>
            <p class="text-xs font-medium uppercase text-gray-500 dark:text-gray-400">Statut</p>
            <span class="mt-1 inline-flex rounded-full px-2 text-xs font-semibold leading-5 <%= project.online? ? 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300' : project.offline? ? 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300' : 'bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-300' %>">
              <%= project.status %>
            </span>
            <% if project.maintenance_mode? %>
              <span class="mt-1 inline-flex rounded-full bg-yellow-100 px-2 text-xs font-semibold leading-5 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300">Maintenance</span>
            <% end %>
          </div>
          <div>
            <p class="text-xs font-medium uppercase text-gray-500 dark:text-gray-400">Retard</p>
            <% if project.commits_behind.to_i > 0 %>
              <p class="mt-1 font-medium text-orange-600 dark:text-orange-400"><%= project.commits_behind %> commits</p>
            <% else %>
              <p class="mt-1 text-green-600 dark:text-green-400">À jour</p>
            <% end %>
          </div>
          <div class="col-span-2">
            <p class="text-xs font-medium uppercase text-gray-500 dark:text-gray-400">Déploiement</p>
            <% if project.last_commit_deployed %>
              <code class="mt-1 inline-flex rounded bg-gray-100 px-1 text-xs dark:bg-gray-800 dark:text-gray-200"><%= project.last_commit_deployed.first(7) %></code>
              <span class="ml-1 text-xs text-gray-400"><%= time_ago_in_words(latest_deployment.created_at) if latest_deployment %></span>
            <% else %>
              <span class="mt-1 block text-gray-400">—</span>
            <% end %>
          </div>
        </div>

        <div class="flex flex-col gap-2 sm:flex-row">
          <%= button_to deploy_project_path(project), method: :post, class: "inline-flex w-full items-center justify-center gap-1.5 rounded border border-transparent bg-indigo-600 px-3 py-2 text-xs font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 sm:w-auto", form: { data: { turbo_confirm: "Déployer #{project.name} ?" } } do %>
            <%= fa_icon(:play, class_name: "h-3 w-3") %>
            Deploy
          <% end %>
          <%= button_to toggle_maintenance_project_path(project), method: :patch,
                class: "inline-flex w-full items-center justify-center gap-1.5 rounded border border-gray-300 bg-white px-3 py-2 text-xs font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-200 dark:hover:bg-gray-800 sm:w-auto" do %>
            <%= fa_icon(:wrench, class_name: "h-3 w-3") %>
            <%= project.maintenance_mode? ? "Désactiver" : "Maintenance" %>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>
</div>
