<section class="mx-auto max-w-7xl space-y-6">
  <div class="rounded-xl border border-gray-800 bg-gray-900 shadow">
    <div class="border-b border-gray-800 px-4 py-5 sm:px-6">
      <div class="flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
        <div class="min-w-0">
          <p class="text-sm font-semibold text-cyan-300">Sentinel overview</p>
          <h2 class="mt-1 text-2xl font-bold text-gray-100">Projects cockpit</h2>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-gray-400">
            Vue rapide des projets qui demandent votre attention : runtime, retard GitHub, cron jobs et maintenance.
          </p>
        </div>

        <%= form_with url: root_path, method: :get, class: "relative w-full xl:max-w-sm", data: { turbo_frame: "_top" } do |form| %>
          <%= fa_icon(:magnifying_glass, class_name: "absolute left-3 top-1/2 -translate-y-1/2 text-sm text-gray-500") %>
          <%= form.search_field :q,
                value: @project_search,
                placeholder: "Search projects",
                class: "w-full rounded-lg border border-gray-700 bg-gray-950 px-10 py-2.5 text-sm text-gray-100 placeholder:text-gray-500 focus:border-cyan-400 focus:outline-none focus:ring-1 focus:ring-cyan-400" %>
        <% end %>
      </div>

      <div class="mt-5 grid grid-cols-2 gap-3 text-sm sm:grid-cols-3 xl:grid-cols-6">
        <div class="rounded-lg border border-gray-800 bg-gray-950 px-4 py-3">
          <p class="text-xs font-medium text-gray-500">Projects</p>
          <p class="mt-1 text-xl font-bold text-gray-100"><%= @projects.size %></p>
        </div>

        <div class="rounded-lg border border-gray-800 bg-gray-950 px-4 py-3">
          <p class="text-xs font-medium text-gray-500">Online</p>
          <p class="mt-1 text-xl font-bold text-green-300"><%= @projects.count(&:online?) %></p>
        </div>

        <div class="rounded-lg border border-gray-800 bg-gray-950 px-4 py-3">
          <p class="text-xs font-medium text-gray-500">Offline</p>
          <p class="mt-1 text-xl font-bold text-red-300"><%= @projects.count(&:offline?) %></p>
        </div>

        <div class="rounded-lg border border-gray-800 bg-gray-950 px-4 py-3">
          <p class="text-xs font-medium text-gray-500">Behind</p>
          <p class="mt-1 text-xl font-bold text-yellow-300">
            <%= @projects.count { |project| project.commits_behind.to_i.positive? } %>
          </p>
        </div>

        <div class="rounded-lg border border-gray-800 bg-gray-950 px-4 py-3">
          <p class="text-xs font-medium text-gray-500">Cron issues</p>
          <p class="mt-1 text-xl font-bold text-red-300">
            <%= @projects.count { |project| project.cron_summary_status == "failed" } %>
          </p>
        </div>

        <div class="rounded-lg border border-gray-800 bg-gray-950 px-4 py-3">
          <p class="text-xs font-medium text-gray-500">Maintenance</p>
          <p class="mt-1 text-xl font-bold text-yellow-300"><%= @projects.count(&:maintenance_mode?) %></p>
        </div>
      </div>
    </div>

    <div class="divide-y divide-gray-800">
      <% if @projects.any? %>
        <% @projects.each do |project| %>
          <% latest_deployment = @latest_deployments_by_project_id[project.id] %>
          <% running_deployment = @running_deployments_by_project_id[project.id] %>
          <% latest_ping = @latest_pings_by_project_id[project.id] %>
          <% cron_status = project.cron_summary_status %>
          <% behind_count = project.commits_behind.to_i %>
          <% needs_attention = project.offline? || behind_count.positive? || cron_status == "failed" || project.maintenance_mode? %>

          <article class="group px-4 py-5 transition hover:bg-gray-800/30 sm:px-6">
            <div class="grid grid-cols-1 gap-5 xl:grid-cols-[minmax(0,1.45fr)_minmax(28rem,1fr)_12rem] xl:items-center">
              <div class="flex min-w-0 gap-4">
                <div class="hidden overflow-hidden rounded-lg border border-gray-800 bg-gray-950 sm:block sm:w-36 sm:shrink-0">
                  <% if @screenshots_enabled && project.screenshot.attached? %>
                    <img src="<%= url_for(project.screenshot) %>"
                         alt="Aperçu de <%= project.name %>"
                         class="aspect-video w-full object-cover opacity-90 transition group-hover:opacity-100"
                         loading="lazy">
                  <% else %>
                    <div class="flex aspect-video w-full items-center justify-center text-xs text-gray-600">No preview</div>
                  <% end %>
                </div>

                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-2">
                    <%= link_to project.name,
                          project_path(project),
                          class: "break-words text-base font-bold text-gray-100 hover:text-cyan-300" %>

                    <% if needs_attention %>
                      <span class="inline-flex items-center rounded-full bg-yellow-900/40 px-2 py-0.5 text-xs font-semibold text-yellow-300">
                        Warning
                      </span>
                    <% else %>
                      <span class="inline-flex items-center rounded-full bg-green-900/40 px-2 py-0.5 text-xs font-semibold text-green-300">
                        Good
                      </span>
                    <% end %>

                    <% if project.maintenance_mode? %>
                      <span class="inline-flex items-center rounded-full bg-yellow-900/40 px-2 py-0.5 text-xs font-semibold text-yellow-300">
                        Maintenance
                      </span>
                    <% end %>
                  </div>

                  <p class="mt-1 break-all text-sm text-gray-400">
                    <%= project.production_url %>
                  </p>

                  <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-gray-500">
                    <span class="font-mono"><%= project.github_repo %></span>
                    <span>Branch <span class="font-mono text-gray-400"><%= project.branch %></span></span>

                    <% if latest_deployment %>
                      <span>Last deploy <%= time_ago_in_words(latest_deployment.created_at) %> ago</span>
                    <% else %>
                      <span>No deploy yet</span>
                    <% end %>

                    <% if latest_ping %>
                      <span>Runtime <%= time_ago_in_words(latest_ping.checked_at || latest_ping.created_at) %> ago</span>
                    <% else %>
                      <span>Runtime never checked</span>
                    <% end %>
                  </div>
                </div>
              </div>

              <div class="grid grid-cols-2 gap-3 text-sm sm:grid-cols-4">
                <div class="rounded-lg border border-gray-800 bg-gray-950/70 px-3 py-3">
                  <p class="text-xs font-medium text-gray-500">Site status</p>
                  <p class="mt-1 inline-flex items-center gap-2 font-semibold <%= project.online? ? 'text-green-300' : project.offline? ? 'text-red-300' : 'text-gray-300' %>">
                    <span class="h-1.5 w-1.5 rounded-full <%= project.online? ? 'bg-green-300' : project.offline? ? 'bg-red-300' : 'bg-gray-500' %>"></span>
                    <%= project.status %>
                  </p>

                  <% if latest_ping&.http_status %>
                    <p class="mt-1 text-xs text-gray-500">HTTP <%= latest_ping.http_status %></p>
                  <% else %>
                    <p class="mt-1 text-xs text-gray-600">No code</p>
                  <% end %>
                </div>

                <div class="rounded-lg border border-gray-800 bg-gray-950/70 px-3 py-3">
                  <p class="text-xs font-medium text-gray-500">Version</p>
                  <p class="mt-1 font-semibold <%= behind_count.positive? ? 'text-yellow-300' : 'text-green-300' %>">
                    <%= behind_count.positive? ? "#{behind_count} update(s)" : "Up to date" %>
                  </p>

                  <p class="mt-1 truncate text-xs text-gray-500">
                    prod
                    <span class="font-mono text-gray-400">
                      <%= project.last_commit_deployed.present? ? project.last_commit_deployed.first(7) : "unknown" %>
                    </span>
                  </p>
                </div>

                <div class="rounded-lg border border-gray-800 bg-gray-950/70 px-3 py-3">
                  <p class="text-xs font-medium text-gray-500">Jobs</p>
                  <p class="mt-1 font-semibold <%= cron_status == 'ok' ? 'text-green-300' : cron_status == 'failed' ? 'text-red-300' : 'text-gray-300' %>">
                    <%= cron_status %>
                  </p>

                  <% if project.cron_synced_at %>
                    <p class="mt-1 text-xs text-gray-500"><%= time_ago_in_words(project.cron_synced_at) %> ago</p>
                  <% else %>
                    <p class="mt-1 text-xs text-gray-600">Never synced</p>
                  <% end %>
                </div>

                <div class="rounded-lg border border-gray-800 bg-gray-950/70 px-3 py-3">
                  <p class="text-xs font-medium text-gray-500">GitHub</p>
                  <p class="mt-1 font-semibold <%= project.open_pull_requests_count.positive? ? 'text-cyan-300' : 'text-gray-300' %>">
                    <%= project.open_pull_requests_count %> open PR
                    </p>

                  <p class="mt-1 text-xs text-gray-500">
                    <%= project.merged_pull_requests_count %> merged
                  </p>
                </div>
              </div>

              <div class="flex flex-col gap-2 xl:items-end">
                <% if running_deployment %>
                  <span class="inline-flex w-full items-center justify-center gap-2 rounded-md bg-gray-800 px-3 py-2 text-sm font-semibold text-gray-400 xl:w-40"
                        title="Un déploiement est déjà en cours">
                    <%= fa_icon(:rotate, class_name: "text-sm") %>
                    Running
                  </span>
                <% elsif behind_count.positive? %>
                  <%= button_to deploy_project_path(project),
                        method: :post,
                        class: "inline-flex w-full cursor-pointer items-center justify-center gap-2 rounded-md bg-cyan-300 px-3 py-2 text-sm font-bold text-gray-950 hover:bg-cyan-200 xl:w-40",
                        title: "Déploie le dernier commit connu de la branche suivie",
                        aria: { label: "Déployer #{project.name}" } do %>
                    <%= fa_icon(:play, class_name: "text-sm") %>
                    Deploy
                  <% end %>
                <% else %>
                  <%= link_to project_path(project),
                        class: "inline-flex w-full items-center justify-center gap-2 rounded-md border border-gray-700 px-3 py-2 text-sm font-semibold text-gray-200 hover:border-gray-500 hover:bg-gray-800 xl:w-40",
                        title: "Ouvre la page détaillée du projet" do %>
                    Open project
                  <% end %>
                <% end %>

                <details class="group/menu relative w-full xl:w-40">
                  <summary class="flex w-full cursor-pointer list-none items-center justify-center gap-2 rounded-md border border-gray-800 px-3 py-2 text-sm font-semibold text-gray-400 hover:border-gray-600 hover:bg-gray-800 hover:text-gray-100">
                    <%= fa_icon(:ellipsis, class_name: "text-base") %>
                    More
                  </summary>

                  <div class="absolute right-0 z-20 mt-2 w-56 overflow-hidden rounded-lg border border-gray-800 bg-gray-950 shadow-xl">
                    <%= link_to project_path(project),
                          class: "flex w-full items-center gap-2 px-4 py-2.5 text-left text-sm font-medium text-gray-300 hover:bg-gray-800 hover:text-gray-100" do %>
                      <%= fa_icon(:arrow_up_right_from_square, class_name: "text-sm text-gray-500") %>
                      Open project
                    <% end %>

                    <%= button_to refresh_github_commits_project_path(project),
                          method: :post,
                          class: "flex w-full cursor-pointer items-center gap-2 px-4 py-2.5 text-left text-sm font-medium text-gray-300 hover:bg-gray-800 hover:text-gray-100",
                          title: "Synchronise les commits et pull requests GitHub pour ce projet",
                          aria: { label: "Synchroniser GitHub pour #{project.name}" } do %>
                      <%= fa_icon(:rotate, class_name: "text-sm text-gray-500") %>
                      Sync GitHub
                    <% end %>

                    <%= button_to refresh_runtime_project_path(project),
                          method: :post,
                          class: "flex w-full cursor-pointer items-center gap-2 px-4 py-2.5 text-left text-sm font-medium text-gray-300 hover:bg-gray-800 hover:text-gray-100",
                          title: "Lance un healthcheck HTTP immédiat pour ce projet",
                          aria: { label: "Vérifier le runtime de #{project.name}" } do %>
                      <%= fa_icon(:heart_pulse, class_name: "text-sm text-gray-500") %>
                      Check status
                    <% end %>

                    <%= button_to refresh_cron_status_project_path(project),
                          method: :post,
                          class: "flex w-full cursor-pointer items-center gap-2 px-4 py-2.5 text-left text-sm font-medium text-gray-300 hover:bg-gray-800 hover:text-gray-100",
                          title: "Synchronise les statuts cron publiés par le projet",
                          aria: { label: "Synchroniser les statuts cron de #{project.name}" } do %>
                      <%= fa_icon(:clock, class_name: "text-sm text-gray-500") %>
                      Sync cron
                    <% end %>
                  </div>
                </details>
              </div>
            </div>
          </article>
        <% end %>
      <% else %>
        <div class="px-6 py-12 text-center">
          <p class="text-sm font-semibold text-gray-300">No project matches this search.</p>
          <p class="mt-1 text-sm text-gray-500">Essayez un autre nom de projet ou videz la recherche.</p>
        </div>
      <% end %>
    </div>
  </div>
</section>
