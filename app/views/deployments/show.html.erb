<section class="mx-auto max-w-7xl space-y-6">
  <nav class="flex flex-wrap items-center gap-3 text-sm text-gray-400">
    <%= link_to "Deployments", deploys_path, class: "hover:text-gray-100" %>
    <span>/</span>
    <%= link_to @project.name, @project, class: "hover:text-gray-100" %>
    <span>/</span>
    <span class="font-semibold text-gray-200"><%= @deployment.commit_sha.first(7) %></span>
  </nav>

  <header class="rounded-lg border border-gray-800 bg-gray-900 p-5 shadow sm:p-6">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
      <div class="min-w-0">
        <p class="text-sm font-semibold text-gray-400"><%= @project.name %></p>
        <h1 class="mt-2 break-words text-2xl font-bold text-gray-100">
          Deployment
          <%= @deployment.commit_sha.first(7) %>
        </h1>
        <p class="mt-3 text-sm text-gray-400">
          Triggered by
          <span class="font-semibold text-gray-200"><%= @deployment.triggered_by.presence || "unknown" %></span>
          on
          <%= l(@deployment.created_at, format: :long) %>.
        </p>
      </div>

      <span
        class="
          inline-flex w-fit rounded-md px-3 py-1 text-sm font-semibold
          <%= @deployment.success? ? 'bg-green-900/40 text-green-300' : @deployment.failed? ? 'bg-red-900/40 text-red-300' : 'bg-yellow-900/40 text-yellow-300' %>
        ">
        <%= @deployment.status %>
      </span>
    </div>
  </header>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_22rem]">
    <section
      class="
        overflow-hidden rounded-lg border border-gray-800 bg-gray-900 shadow
      ">
      <div class="border-b border-gray-800 px-5 py-4">
        <h2 class="text-xl font-bold text-gray-100">Logs</h2>
      </div>

      <% if @deployment.log.present? %>
        <pre
          class="
            max-h-[42rem] overflow-auto whitespace-pre-wrap break-words bg-gray-950 p-5
            text-xs leading-6 text-gray-200
          "><%= @deployment.log %></pre>
      <% else %>
        <p class="px-5 py-10 text-sm text-gray-400">No logs recorded for this deployment.</p>
      <% end %>
    </section>

    <aside class="space-y-6">
      <section class="rounded-lg border border-gray-800 bg-gray-900 p-5 shadow">
        <h2 class="text-lg font-bold text-gray-100">Details</h2>
        <dl class="mt-5 space-y-4 text-sm">
          <div>
            <dt class="text-gray-500">Project</dt>
            <dd class="mt-1 font-semibold text-gray-100"><%= link_to @project.name, @project, class: "hover:underline" %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Commit</dt>
            <dd class="mt-1 break-all font-mono text-gray-100"><%= @deployment.commit_sha %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Branch</dt>
            <dd class="mt-1 font-semibold text-gray-100"><%= @project.branch %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Duration</dt>
            <dd class="mt-1 font-semibold text-gray-100"><%= @deployment.duration ? "#{@deployment.duration}s" : "-" %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Triggered by</dt>
            <dd class="mt-1 font-semibold text-gray-100"><%= @deployment.triggered_by.presence || "unknown" %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Started</dt>
            <dd class="mt-1 font-semibold text-gray-100"><%= l(@deployment.created_at, format: :short) %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Updated</dt>
            <dd class="mt-1 font-semibold text-gray-100"><%= l(@deployment.updated_at, format: :short) %></dd>
          </div>
        </dl>
      </section>

      <section class="rounded-lg border border-gray-800 bg-gray-900 p-5 shadow">
        <h2 class="text-lg font-bold text-gray-100">VPS</h2>
        <dl class="mt-5 space-y-4 text-sm">
          <div>
            <dt class="text-gray-500">Path</dt>
            <dd class="mt-1 break-all font-mono text-gray-100"><%= @project.vps_path %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Deploy script</dt>
            <dd class="mt-1 font-mono text-gray-100">deploy.sh</dd>
          </div>
        </dl>
      </section>
    </aside>
  </div>
</section>
