<div class="rounded-lg bg-white p-4 shadow dark:bg-gray-900 sm:p-6">
  <h2 class="text-xl font-semibold mb-4">Derniers déploiements</h2>
  <% if @deployments.any? %>
    <div class="hidden overflow-x-auto md:block">
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
      <thead class="bg-gray-50 dark:bg-gray-800">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase dark:text-gray-400">Projet</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase dark:text-gray-400">Commit</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase dark:text-gray-400">Statut</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase dark:text-gray-400">Durée</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase dark:text-gray-400">Date</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 dark:divide-gray-800">
        <% @deployments.each do |deploy| %>
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/70">
            <td class="px-6 py-4"><%= link_to deploy.project.name, deploy.project, class: "hover:underline" %></td>
            <td class="px-6 py-4"><code class="text-xs bg-gray-100 px-1 rounded dark:bg-gray-800 dark:text-gray-200"><%= deploy.commit_sha.first(7) %></code></td>
            <td class="px-6 py-4"><span class="<%= deploy.success? ? 'text-green-600 dark:text-green-400' : deploy.failed? ? 'text-red-600 dark:text-red-400' : 'text-yellow-600 dark:text-yellow-400' %>"><%= deploy.status %></span></td>
            <td class="px-6 py-4"><%= deploy.duration ? "#{deploy.duration}s" : '-' %></td>
            <td class="px-6 py-4"><%= l(deploy.created_at, format: :short) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>

    <div class="divide-y divide-gray-200 dark:divide-gray-800 md:hidden">
      <% @deployments.each do |deploy| %>
        <article class="space-y-3 py-4">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-gray-100">
                <%= link_to deploy.project.name, deploy.project, class: "hover:underline" %>
              </h3>
              <code class="mt-1 inline-flex rounded bg-gray-100 px-1 text-xs dark:bg-gray-800 dark:text-gray-200"><%= deploy.commit_sha.first(7) %></code>
            </div>
            <span class="text-sm font-medium <%= deploy.success? ? 'text-green-600 dark:text-green-400' : deploy.failed? ? 'text-red-600 dark:text-red-400' : 'text-yellow-600 dark:text-yellow-400' %>"><%= deploy.status %></span>
          </div>
          <dl class="grid grid-cols-2 gap-3 text-sm">
            <div>
              <dt class="text-xs font-medium uppercase text-gray-500 dark:text-gray-400">Durée</dt>
              <dd class="mt-1"><%= deploy.duration ? "#{deploy.duration}s" : '-' %></dd>
            </div>
            <div>
              <dt class="text-xs font-medium uppercase text-gray-500 dark:text-gray-400">Date</dt>
              <dd class="mt-1"><%= l(deploy.created_at, format: :short) %></dd>
            </div>
          </dl>
        </article>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500 dark:text-gray-400">Aucun déploiement enregistré pour le moment.</p>
  <% end %>
</div>
