<div class="bg-white shadow rounded-lg p-6">
  <h2 class="text-xl font-semibold mb-4">Derniers déploiements</h2>
  <% if @deployments.any? %>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Projet</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Commit</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Statut</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Durée</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Date</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @deployments.each do |deploy| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4"><%= link_to deploy.project.name, deploy.project %></td>
            <td class="px-6 py-4"><code class="text-xs bg-gray-100 px-1 rounded"><%= deploy.commit_sha.first(7) %></code></td>
            <td class="px-6 py-4"><span class="<%= deploy.success? ? 'text-green-600' : deploy.failed? ? 'text-red-600' : 'text-yellow-600' %>"><%= deploy.status %></span></td>
            <td class="px-6 py-4"><%= deploy.duration ? "#{deploy.duration}s" : '-' %></td>
            <td class="px-6 py-4"><%= l(deploy.created_at, format: :short) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-gray-500">Aucun déploiement enregistré pour le moment.</p>
  <% end %>
</div>
