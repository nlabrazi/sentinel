<div class="space-y-8">
  <section class="max-w-4xl rounded-lg border border-gray-200 bg-white p-6 shadow dark:border-gray-800 dark:bg-gray-900">
    <div class="flex flex-wrap items-center gap-2">
      <h1 class="text-xl font-bold text-gray-900 dark:text-gray-100">Settings for <%= @settings_summary[:app_name] %></h1>
      <span class="rounded bg-gray-200 px-2 py-0.5 text-xs font-semibold text-gray-800 dark:bg-gray-700 dark:text-gray-100"><%= @settings_summary[:environment] %></span>
      <span class="rounded bg-gray-200 px-2 py-0.5 text-xs font-semibold text-gray-800 dark:bg-gray-700 dark:text-gray-100">Read-only</span>
    </div>
    <p class="mt-3 text-sm text-gray-600 dark:text-gray-300"><%= @settings_summary[:project_count] %> managed project(s).</p>
    <p class="mt-4 text-sm text-gray-600 dark:text-gray-300">
      <% if @settings_summary[:created_at] %>
        First project created on <%= l(@settings_summary[:created_at].to_date, format: :long) %>.
      <% else %>
        No project has been registered yet.
      <% end %>
    </p>
  </section>

  <div class="flex flex-col gap-8 lg:flex-row">
    <aside class="w-full shrink-0 text-sm lg:w-64">
      <nav class="space-y-6">
        <div>
          <a href="#general" class="flex items-center gap-2 font-semibold text-indigo-600 dark:text-indigo-400">
            <span class="h-2 w-2 rotate-45 bg-indigo-500"></span>
            General
          </a>
          <div class="mt-4 space-y-3 pl-8 text-gray-500 dark:text-gray-400">
            <a href="#application-information" class="block hover:text-gray-900 dark:hover:text-gray-100">Application details</a>
            <a href="#access-policy" class="block hover:text-gray-900 dark:hover:text-gray-100">Access policy</a>
          </div>
        </div>

        <div>
          <a href="#environment-variables" class="font-semibold text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100">Environment variables</a>
        </div>

        <div>
          <a href="#access-security" class="font-semibold text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100">Access & security</a>
        </div>
      </nav>
    </aside>

    <main class="min-w-0 flex-1 space-y-10">
      <section id="general" class="space-y-8">
        <div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">General app settings</h2>
        </div>

        <div id="application-information" class="space-y-4">
          <div>
            <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Application details</h3>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Application profile and operational information</p>
          </div>

          <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow dark:border-gray-800 dark:bg-gray-900">
            <div class="border-b border-gray-200 px-6 py-4 dark:border-gray-800">
              <h4 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Application information</h4>
            </div>

            <div class="divide-y divide-gray-100 dark:divide-gray-800">
              <% @settings_sections[:application_information].each_with_index do |(label, value), index| %>
                <div class="grid grid-cols-1 gap-2 px-6 py-4 text-sm <%= index.odd? ? 'bg-gray-50 dark:bg-gray-800/70' : '' %> sm:grid-cols-3">
                  <dt class="font-medium text-gray-900 dark:text-gray-100"><%= label %>:</dt>
                  <dd class="break-words font-semibold text-gray-900 dark:text-gray-100 sm:col-span-2"><%= value %></dd>
                </div>
              <% end %>
            </div>
          </div>
        </div>

        <div id="access-policy" class="space-y-1">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Access policy</h3>
          <p class="text-sm text-gray-500 dark:text-gray-400">The application requires authentication before exposing project or deployment data.</p>
        </div>
      </section>

      <section id="environment-variables" class="space-y-4">
        <div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">Environment variables</h2>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Runtime configuration status. Secret values are never displayed.</p>
        </div>

        <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow dark:border-gray-800 dark:bg-gray-900">
          <div class="divide-y divide-gray-100 dark:divide-gray-800">
            <% @settings_sections[:environment_variables].each_with_index do |(label, value), index| %>
              <div class="grid grid-cols-1 gap-2 px-6 py-4 text-sm <%= index.odd? ? 'bg-gray-50 dark:bg-gray-800/70' : '' %> sm:grid-cols-3">
                <dt class="font-medium text-gray-900 dark:text-gray-100"><%= label %>:</dt>
                <dd class="sm:col-span-2">
                  <% if value == "Configured" %>
                    <span class="rounded-full bg-green-100 px-2 py-0.5 text-xs font-semibold text-green-800 dark:bg-green-900/30 dark:text-green-300">Configured</span>
                  <% elsif value == "Missing" %>
                    <span class="rounded-full bg-red-100 px-2 py-0.5 text-xs font-semibold text-red-800 dark:bg-red-900/30 dark:text-red-300">Missing</span>
                  <% else %>
                    <span class="break-words font-semibold text-gray-900 dark:text-gray-100"><%= value %></span>
                  <% end %>
                </dd>
              </div>
            <% end %>
          </div>
        </div>
      </section>

      <section id="access-security" class="space-y-4">
        <div>
          <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">Access & security</h2>
          <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Authentication, CI and audit posture</p>
        </div>

        <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow dark:border-gray-800 dark:bg-gray-900">
          <div class="divide-y divide-gray-100 dark:divide-gray-800">
            <% @settings_sections[:access_security].each_with_index do |(label, value), index| %>
              <div class="grid grid-cols-1 gap-2 px-6 py-4 text-sm <%= index.odd? ? 'bg-gray-50 dark:bg-gray-800/70' : '' %> sm:grid-cols-3">
                <dt class="font-medium text-gray-900 dark:text-gray-100"><%= label %>:</dt>
                <dd class="break-words font-semibold text-gray-900 dark:text-gray-100 sm:col-span-2"><%= value %></dd>
              </div>
            <% end %>
          </div>
        </div>
      </section>
    </main>
  </div>
</div>
