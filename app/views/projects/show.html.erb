<section class="w-full space-y-6">
  <nav class="flex flex-wrap items-center gap-3 text-sm text-gray-400">
    <%= link_to "Projects", root_path, class: "hover:text-gray-100" %>
    <span>/</span>
    <span class="font-semibold text-gray-200"><%= @project.name %></span>
    <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-gray-900 text-gray-400">
      <%= fa_icon(:rotate, class_name: "h-4 w-4") %>
    </span>
  </nav>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-[13rem_minmax(0,1fr)]">
    <aside class="hidden text-sm lg:block">
      <nav class="space-y-4 text-gray-400">
        <a href="#overview" class="flex items-center gap-2 font-semibold text-cyan-300">
          <span class="h-2 w-2 rotate-45 bg-cyan-300"></span>
          Project overview
        </a>
        <a href="#commits" class="block pl-6 hover:text-gray-100">Commits</a>
        <a href="#pull-requests" class="block pl-6 hover:text-gray-100">Pull requests</a>
        <a href="#configuration" class="block pl-6 hover:text-gray-100">Project configuration</a>
        <a href="#cron-jobs" class="block pl-6 hover:text-gray-100">Cron jobs</a>
        <a href="#deploys" class="block pl-6 hover:text-gray-100">Deploys</a>
        <a href="#healthcheck" class="block pl-6 hover:text-gray-100">Healthcheck</a>
      </nav>
    </aside>

    <div class="min-w-0 space-y-6">
  <div id="overview" class="grid grid-cols-1 gap-6 xl:grid-cols-[minmax(0,1.35fr)_minmax(22rem,1fr)]">
    <article class="rounded-lg border border-gray-800 bg-gray-900 p-6 shadow">
      <div class="flex flex-col gap-5 md:flex-row md:items-start">
        <div class="relative overflow-hidden rounded border border-gray-800 bg-gray-950 md:w-56 md:shrink-0 md:self-start">
          <% if @project.screenshot.attached? %>
            <img src="<%= url_for(@project.screenshot) %>"
                 alt="Aperçu de <%= @project.name %>"
                 class="aspect-video w-full object-cover"
                 loading="lazy">
          <% else %>
            <div class="flex aspect-video w-full items-center justify-center text-xs text-gray-500">No preview</div>
          <% end %>
          <span class="absolute right-2 top-2 rounded-md bg-gray-800 p-2 text-gray-300"><%= fa_icon(:gear, class_name: "h-4 w-4") %></span>
        </div>

        <div class="min-w-0 flex-1">
          <h1 class="break-words text-2xl font-bold text-gray-100"><%= @project.name %></h1>
          <p class="mt-2 flex items-center gap-2 text-sm font-semibold <%= @project.online? ? 'text-green-400' : @project.offline? ? 'text-red-400' : 'text-gray-400' %>">
            <span class="h-2 w-2 rounded-full <%= @project.online? ? 'bg-green-400' : @project.offline? ? 'bg-red-400' : 'bg-gray-500' %>"></span>
            <%= @project.production_url %>
          </p>
          <p class="mt-4 text-gray-300">Deploys from GitHub with <%= @project.branch %>.</p>
          <% if @deployments.first %>
            <p class="mt-3 text-gray-300">Published <%= time_ago_in_words(@deployments.first.created_at) %> ago.</p>
          <% else %>
            <p class="mt-3 text-gray-400">No production deploy has completed yet.</p>
          <% end %>
          <% if @running_deployment %>
            <p class="mt-3 rounded-md border border-yellow-900/60 bg-yellow-950/40 px-3 py-2 text-sm font-semibold text-yellow-200">
              Deployment running since <%= time_ago_in_words(@running_deployment.created_at) %> ago.
            </p>
          <% end %>

          <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-6">
            <%= button_to refresh_github_commits_project_path(@project),
                  method: :post,
                  class: "inline-flex w-full cursor-pointer items-center justify-center gap-2 rounded border border-cyan-900/60 px-3 py-1.5 text-xs font-semibold text-cyan-300 hover:bg-cyan-950/40",
                  title: "Synchronise les commits et pull requests GitHub",
                  aria: { label: "Synchroniser GitHub" } do %>
              <%= fa_icon(:rotate, class_name: "h-3.5 w-3.5") %>
              Sync GitHub
            <% end %>
            <%= button_to refresh_runtime_project_path(@project),
                  method: :post,
                  class: "inline-flex w-full cursor-pointer items-center justify-center gap-2 rounded border border-sky-900/60 px-3 py-1.5 text-xs font-semibold text-sky-300 hover:bg-sky-950/40",
                  title: "Lance un healthcheck HTTP immédiat",
                  aria: { label: "Vérifier le runtime" } do %>
              <%= fa_icon(:rotate, class_name: "h-3.5 w-3.5") %>
              Check status
            <% end %>
            <%= button_to refresh_cron_status_project_path(@project),
                  method: :post,
                  class: "inline-flex w-full cursor-pointer items-center justify-center gap-2 rounded border border-emerald-900/60 px-3 py-1.5 text-xs font-semibold text-emerald-300 hover:bg-emerald-950/40",
                  title: "Synchronise les statuts cron publiés par le projet",
                  aria: { label: "Synchroniser les statuts cron" } do %>
              <%= fa_icon(:rotate, class_name: "h-3.5 w-3.5") %>
              Sync cron
            <% end %>
            <% if @running_deployment %>
              <span class="inline-flex w-full items-center justify-center gap-2 rounded border border-yellow-900/60 px-3 py-1.5 text-xs font-semibold text-yellow-300" title="Un déploiement est déjà en cours">
                <%= fa_icon(:rotate, class_name: "h-3.5 w-3.5") %>
                Deploy running
              </span>
            <% else %>
              <%= button_to deploy_project_path(@project),
                    method: :post,
                    class: "inline-flex w-full cursor-pointer items-center justify-center gap-2 rounded border border-green-900/60 bg-green-950/60 px-3 py-1.5 text-xs font-semibold text-green-200 hover:bg-green-900/40",
                    title: "Déploie le dernier commit disponible pour ce projet",
                    aria: { label: "Déployer le dernier commit" } do %>
                <%= fa_icon(:play, class_name: "h-3.5 w-3.5") %>
                Deploy latest
              <% end %>
            <% end %>
            <%= button_to toggle_maintenance_project_path(@project), method: :patch,
                  class: "inline-flex w-full cursor-pointer items-center justify-center gap-2 rounded border border-yellow-900/60 px-3 py-1.5 text-xs font-semibold text-yellow-300 hover:bg-yellow-950/40",
                  title: "Active ou désactive le mode maintenance côté VPS",
                  aria: { label: "Basculer le mode maintenance" } do %>
              <%= fa_icon(:wrench, class_name: "h-3.5 w-3.5") %>
              <%= @project.maintenance_mode? ? "Disable maint." : "Enable maint." %>
            <% end %>
            <%= button_to refresh_screenshot_project_path(@project),
                  method: :post,
                  class: "inline-flex w-full cursor-pointer items-center justify-center gap-2 rounded border border-indigo-900/60 px-3 py-1.5 text-xs font-semibold text-indigo-400 hover:bg-indigo-950/40",
                  title: "Régénère l’aperçu visuel du site",
                  aria: { label: "Rafraîchir l’aperçu" } do %>
              <%= fa_icon(:rotate, class_name: "h-3.5 w-3.5") %>
              Refresh preview
            <% end %>
          </div>
        </div>
      </div>
    </article>

    <aside class="overflow-hidden rounded-lg border border-gray-800 bg-gray-900 shadow">
      <div class="h-1.5 bg-indigo-600"></div>
      <div class="grid min-h-56 grid-cols-[1fr_8rem] gap-4 p-6">
        <div>
          <h2 class="text-xl font-bold text-gray-100">Release readiness</h2>
          <p class="mt-3 text-sm leading-6 text-gray-400">
            Review deployment health before shipping: maintenance mode, commit drift, latest production status, and SSH configuration.
          </p>
          <dl class="mt-5 grid grid-cols-1 gap-3 text-sm sm:grid-cols-2">
            <div>
              <dt class="text-gray-500">Maintenance</dt>
              <dd class="mt-1 font-semibold text-gray-100"><%= @project.maintenance_mode? ? "Enabled" : "Disabled" %></dd>
            </div>
            <div>
              <dt class="text-gray-500">Commit drift</dt>
              <dd class="mt-1 font-semibold text-gray-100"><%= @project.commits_behind.to_i %> commit(s)</dd>
            </div>
            <div class="sm:col-span-2">
              <dt class="text-gray-500">Deployment state</dt>
              <dd class="mt-1 font-semibold <%= @running_deployment ? 'text-yellow-300' : 'text-gray-100' %>">
                <%= @running_deployment ? "Running" : "Idle" %>
              </dd>
            </div>
          </dl>
        </div>
        <div class="hidden items-end justify-center sm:flex">
          <div class="relative h-28 w-24 rounded-t-3xl bg-gray-700">
            <div class="absolute -top-12 left-1/2 h-16 w-16 -translate-x-1/2 rounded-t-full border-8 border-gray-700 border-b-0"></div>
          </div>
        </div>
      </div>
    </aside>
  </div>

  <section id="commits" class="overflow-hidden rounded-lg border border-gray-800 bg-gray-900 shadow">
    <div class="border-b border-gray-800 px-5 py-4">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-xl font-bold text-gray-100">Recent commits</h2>
          <p class="mt-1 text-sm text-gray-400">
            Latest commits synchronized from the tracked GitHub branch.
            <% if @project.github_synced_at %>
              GitHub synced <%= time_ago_in_words(@project.github_synced_at) %> ago.
            <% else %>
              GitHub never synced.
            <% end %>
          </p>
        </div>
        <span class="inline-flex w-fit items-center rounded-full bg-gray-800 px-3 py-1 text-xs font-semibold text-gray-300">
          <%= @github_commits.size %> commit<%= "s" unless @github_commits.size == 1 %>
        </span>
      </div>
    </div>

    <% if @github_commits.any? %>
      <div class="divide-y divide-gray-800">
        <% @github_commits.each do |commit| %>
          <% short_sha = commit.sha.first(7) %>
          <article class="flex flex-col gap-3 px-5 py-4 md:flex-row md:items-center md:justify-between">
            <div class="min-w-0">
              <p class="truncate font-semibold text-gray-100">
                <%= commit.message %>
              </p>
              <p class="mt-1 text-sm text-gray-400">
                <code class="rounded bg-gray-950 px-1.5 py-0.5 text-xs text-gray-200"><%= short_sha %></code>
                <% if commit.author_login.present? || commit.author_name.present? %>
                  <span class="mx-1 text-gray-600">·</span>
                  <%= commit.author_login.presence || commit.author_name %>
                <% end %>
              </p>
            </div>
            <p class="shrink-0 text-sm text-gray-400">
              <% if commit.committed_at %>
                <%= l(commit.committed_at, format: :short) %>
              <% else %>
                unknown
              <% end %>
            </p>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="px-5 py-6 text-sm text-gray-400">
        No GitHub commit history has been synchronized yet.
      </div>
    <% end %>
  </section>

  <section id="pull-requests" class="overflow-hidden rounded-lg border border-gray-800 bg-gray-900 shadow">
    <div class="border-b border-gray-800 px-5 py-4">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-xl font-bold text-gray-100">Pull requests</h2>
          <p class="mt-1 text-sm text-gray-400">
            Open and recently updated GitHub pull requests for this repository.
            <% if @project.github_synced_at %>
              GitHub synced <%= time_ago_in_words(@project.github_synced_at) %> ago.
            <% else %>
              GitHub never synced.
            <% end %>
          </p>
        </div>
        <span class="inline-flex w-fit items-center rounded-full bg-gray-800 px-3 py-1 text-xs font-semibold text-gray-300">
          <%= @github_pull_requests.size %> PR<%= "s" unless @github_pull_requests.size == 1 %>
        </span>
      </div>
    </div>

    <% if @github_pull_requests.any? %>
      <div class="divide-y divide-gray-800">
        <% @github_pull_requests.each do |pull_request| %>
          <article class="flex flex-col gap-3 px-5 py-4 md:flex-row md:items-center md:justify-between">
            <div class="min-w-0">
              <p class="truncate font-semibold text-gray-100">
                #<%= pull_request.number %> <%= pull_request.title %>
              </p>
              <p class="mt-1 text-sm text-gray-400">
                <% if pull_request.author_login.present? %>
                  <%= pull_request.author_login %>
                  <span class="mx-1 text-gray-600">·</span>
                <% end %>
                <span class="font-mono text-xs"><%= pull_request.head_ref.presence || "unknown" %> -> <%= pull_request.base_ref.presence || @project.branch %></span>
              </p>
            </div>
            <div class="flex shrink-0 items-center gap-3 text-sm">
              <span class="inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-xs font-semibold <%= pull_request.state == 'open' ? 'bg-green-900/40 text-green-300' : pull_request.state == 'merged' ? 'bg-purple-900/40 text-purple-300' : 'bg-gray-800 text-gray-300' %>">
                <span class="h-1.5 w-1.5 rounded-full <%= pull_request.state == 'open' ? 'bg-green-300' : pull_request.state == 'merged' ? 'bg-purple-300' : 'bg-gray-400' %>"></span>
                <%= pull_request.state %><%= pull_request.draft? ? " draft" : "" %>
              </span>
              <span class="text-gray-400">
                <% if pull_request.github_updated_at %>
                  <%= l(pull_request.github_updated_at, format: :short) %>
                <% else %>
                  unknown
                <% end %>
              </span>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="px-5 py-6 text-sm text-gray-400">
        No GitHub pull requests have been synchronized yet.
      </div>
    <% end %>
  </section>

  <section id="configuration" class="overflow-hidden rounded-lg border border-gray-800 bg-gray-900 shadow">
    <div class="border-b border-gray-800 bg-gradient-to-r from-indigo-950 via-purple-950 to-gray-900 px-5 py-4">
      <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
        <div>
          <h2 class="text-xl font-bold text-gray-100">Deployment command</h2>
          <p class="mt-1 text-sm text-gray-400">The command Sentinel runs on the VPS for this project.</p>
        </div>
        <div class="flex flex-wrap gap-3 text-sm text-gray-400">
          <span>VPS path</span>
          <span>SSH execution</span>
        </div>
      </div>
    </div>
    <div class="p-5">
      <div class="rounded-lg border border-gray-600 bg-gray-950 p-4">
        <p class="text-sm text-gray-400">Start with</p>
        <code class="mt-3 block overflow-x-auto whitespace-nowrap text-sm text-gray-100"><%= @project.deploy_command %></code>
      </div>
      <p class="mt-4 text-sm text-gray-400">
        The command is generated from the validated VPS path and remains read-only from this screen.
      </p>
    </div>
  </section>

  <section id="cron-jobs" class="overflow-hidden rounded-lg border border-gray-800 bg-gray-900 shadow">
    <div class="border-b border-gray-800 px-5 py-4">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <h2 class="text-xl font-bold text-gray-100">Cron jobs</h2>
          <p class="mt-1 text-sm text-gray-400">
            Latest status reported by the project status script.
            <% if @project.cron_synced_at %>
              Cron synced <%= time_ago_in_words(@project.cron_synced_at) %> ago.
            <% else %>
              Cron never synced.
            <% end %>
          </p>
        </div>
        <div class="flex flex-wrap items-center gap-2">
          <span class="inline-flex w-fit items-center rounded-full bg-gray-800 px-3 py-1 text-xs font-semibold text-gray-300">
            <%= @cron_jobs.size %> job<%= "s" unless @cron_jobs.size == 1 %>
          </span>
          <%= button_to refresh_cron_status_project_path(@project),
                method: :post,
                class: "inline-flex w-fit cursor-pointer items-center justify-center gap-2 rounded border border-gray-700 px-3 py-1.5 text-xs font-semibold text-gray-200 hover:border-gray-500 hover:bg-gray-800",
                title: "Synchronise les statuts cron publiés par le projet",
                aria: { label: "Synchroniser les statuts cron" } do %>
            <%= fa_icon(:rotate, class_name: "h-3.5 w-3.5") %>
            Sync cron
          <% end %>
        </div>
      </div>
    </div>

    <% if @cron_jobs.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-800 text-left text-sm">
          <thead class="bg-gray-950/70 text-xs uppercase text-gray-500">
            <tr>
              <th scope="col" class="px-5 py-3 font-semibold">Name</th>
              <th scope="col" class="px-5 py-3 font-semibold">Schedule</th>
              <th scope="col" class="px-5 py-3 font-semibold">Last run</th>
              <th scope="col" class="px-5 py-3 font-semibold">Status</th>
              <th scope="col" class="px-5 py-3 font-semibold">Duration</th>
              <th scope="col" class="px-5 py-3 font-semibold">Last log</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-800">
            <% @cron_jobs.each do |cron_job| %>
              <% latest_execution = cron_job.job_executions.max_by { |execution| execution.executed_at || execution.created_at } %>
              <% last_log = latest_execution&.log.to_s.squish %>
              <tr class="align-top">
                <td class="px-5 py-4">
                  <p class="font-semibold text-gray-100"><%= cron_job.name %></p>
                  <p class="mt-1 max-w-xs truncate font-mono text-xs text-gray-500"><%= cron_job.command %></p>
                </td>
                <td class="whitespace-nowrap px-5 py-4 font-mono text-gray-300"><%= cron_job.schedule %></td>
                <td class="whitespace-nowrap px-5 py-4 text-gray-300">
                  <% if cron_job.last_execution_at %>
                    <%= l(cron_job.last_execution_at, format: :short) %>
                  <% else %>
                    <span class="text-gray-500">unknown</span>
                  <% end %>
                </td>
                <td class="whitespace-nowrap px-5 py-4">
                  <span class="inline-flex items-center gap-1.5 rounded-full px-2 py-0.5 text-xs font-semibold <%= cron_job.last_status == 'success' ? 'bg-green-900/40 text-green-300' : cron_job.last_status == 'failed' ? 'bg-red-900/40 text-red-300' : 'bg-gray-800 text-gray-300' %>">
                    <span class="h-1.5 w-1.5 rounded-full <%= cron_job.last_status == 'success' ? 'bg-green-300' : cron_job.last_status == 'failed' ? 'bg-red-300' : 'bg-gray-400' %>"></span>
                    <%= cron_job.last_status.presence || "unknown" %>
                  </span>
                </td>
                <td class="whitespace-nowrap px-5 py-4 text-gray-300">
                  <%= cron_job.last_duration.present? ? "#{cron_job.last_duration}s" : "unknown" %>
                </td>
                <td class="px-5 py-4 text-gray-300">
                  <% if last_log.present? %>
                    <p class="max-w-xl truncate"><%= truncate(last_log, length: 140) %></p>
                  <% else %>
                    <span class="text-gray-500">No log reported</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-5 py-6 text-sm text-gray-400">
        No cron status has been reported yet. Use Sync cron once the project exposes its read-only status JSON.
      </div>
    <% end %>
  </section>

  <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
    <section id="deploys" class="rounded-lg border border-gray-800 bg-gray-900 p-6 shadow">
      <div class="flex items-center justify-between border-b border-gray-800 pb-4">
        <h2 class="text-xl font-bold text-gray-100">Production deploys</h2>
        <span class="text-2xl text-gray-600">&rsaquo;</span>
      </div>

      <div class="divide-y divide-gray-800">
        <% if @deployments.any? %>
          <% @deployments.each do |deploy| %>
            <article class="flex items-center justify-between gap-4 py-5">
              <div class="min-w-0">
                <p class="truncate font-semibold text-gray-100">
                  <%= link_to deployment_path(deploy), class: "hover:underline" do %>
                    Production: <%= @project.branch %>@<%= deploy.commit_sha.first(7) %>
                  <% end %>
                  <% if deploy.success? %>
                    <span class="ml-2 rounded bg-green-900/40 px-2 py-0.5 text-xs text-green-300">Published</span>
                  <% elsif deploy.failed? %>
                    <span class="ml-2 rounded bg-red-900/40 px-2 py-0.5 text-xs text-red-300">Failed</span>
                  <% else %>
                    <span class="ml-2 rounded bg-yellow-900/40 px-2 py-0.5 text-xs text-yellow-300"><%= deploy.status %></span>
                  <% end %>
                </p>
                <p class="mt-1 text-sm text-gray-400"><%= l(deploy.created_at, format: :short) %><%= deploy.duration ? " · #{deploy.duration}s" : "" %></p>
              </div>
              <%= link_to deployment_path(deploy), class: "text-2xl text-gray-600 hover:text-gray-300", aria: { label: "View deployment #{deploy.commit_sha.first(7)}" } do %>
                &rsaquo;
              <% end %>
            </article>
          <% end %>
        <% else %>
          <p class="py-6 text-sm text-gray-400">No deployment history yet.</p>
        <% end %>
      </div>
    </section>

    <section id="healthcheck" class="rounded-lg border border-gray-800 bg-gray-900 p-6 shadow">
      <div class="flex flex-col gap-3 border-b border-gray-800 pb-4 sm:flex-row sm:items-center sm:justify-between">
        <h2 class="text-xl font-bold text-gray-100">Healthcheck</h2>
        <%= button_to refresh_runtime_project_path(@project),
              method: :post,
              class: "inline-flex w-fit cursor-pointer items-center justify-center gap-2 rounded border border-gray-700 px-3 py-1.5 text-xs font-semibold text-gray-200 hover:border-gray-500 hover:bg-gray-800",
              title: "Lance un healthcheck HTTP immédiat",
              aria: { label: "Vérifier le runtime" } do %>
          <%= fa_icon(:rotate, class_name: "h-3.5 w-3.5") %>
          Check status
        <% end %>
      </div>

      <dl class="mt-6 grid grid-cols-1 gap-4 text-sm sm:grid-cols-2">
        <div>
          <dt class="text-gray-400">Current status</dt>
          <dd class="mt-2 inline-flex items-center gap-2 font-semibold <%= @project.online? ? 'text-green-400' : @project.offline? ? 'text-red-400' : 'text-gray-300' %>">
            <span class="h-2 w-2 rounded-full <%= @project.online? ? 'bg-green-400' : @project.offline? ? 'bg-red-400' : 'bg-gray-500' %>"></span>
            <%= @project.status %>
          </dd>
        </div>
        <div>
          <dt class="text-gray-400">Maintenance</dt>
          <dd class="mt-2 font-semibold text-gray-100"><%= @project.maintenance_mode? ? "Enabled" : "Disabled" %></dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-gray-400">Production URL</dt>
          <dd class="mt-2 break-all font-semibold text-gray-100"><%= @project.production_url %></dd>
        </div>
        <div>
          <dt class="text-gray-400">Last check</dt>
          <dd class="mt-2 font-semibold text-gray-100">
            <% if @latest_ping %>
              <%= l(@latest_ping.checked_at || @latest_ping.created_at, format: :short) %>
            <% else %>
              Never
            <% end %>
          </dd>
        </div>
        <div>
          <dt class="text-gray-400">Last result</dt>
          <dd class="mt-2 font-semibold <%= @latest_ping&.status == 'online' ? 'text-green-400' : @latest_ping&.status == 'offline' ? 'text-red-400' : 'text-gray-100' %>">
            <%= @latest_ping&.status.presence || "unknown" %>
          </dd>
        </div>
        <div>
          <dt class="text-gray-400">HTTP code</dt>
          <dd class="mt-2 font-semibold text-gray-100"><%= @latest_ping&.http_status || "unknown" %></dd>
        </div>
        <div>
          <dt class="text-gray-400">Response time</dt>
          <dd class="mt-2 font-semibold text-gray-100"><%= @latest_ping&.response_time_ms ? "#{@latest_ping.response_time_ms} ms" : "unknown" %></dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-gray-400">Last error</dt>
          <dd class="mt-2 break-words font-semibold <%= @latest_ping&.error.present? ? 'text-red-300' : 'text-gray-100' %>">
            <%= @latest_ping&.error.presence || "none" %>
          </dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-gray-400">Latest deployment</dt>
          <dd class="mt-2 font-semibold text-gray-100">
            <% if @deployments.first %>
              <%= @deployments.first.status %> · <%= time_ago_in_words(@deployments.first.created_at) %> ago
            <% else %>
              No deployment yet
            <% end %>
          </dd>
        </div>
      </dl>
    </section>
  </div>
    </div>
  </div>
</section>
