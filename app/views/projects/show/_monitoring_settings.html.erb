<section
  id="monitoring-settings"
  class="rounded-lg border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 shadow">
  <div class="flex flex-col gap-2 border-b border-gray-200 dark:border-gray-800 pb-4">
    <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">Monitoring</h2>
    <p class="text-sm text-gray-500 dark:text-gray-400">
      Choisissez explicitement quels signaux Sentinel doit suivre pour ce projet.
    </p>
  </div>

  <%= form_with model: project, url: update_monitoring_project_path(project), method: :patch, class: "mt-6 space-y-4" do |form| %>
    <label class="flex items-start gap-3 rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-950/60 px-4 py-4">
      <%= form.check_box :runtime_monitoring_enabled,
      class: "mt-1 h-4 w-4 rounded border-gray-300 text-cyan-600 focus:ring-cyan-500" %>
      <span class="block">
        <span class="block font-semibold text-gray-900 dark:text-gray-100">HTTP healthcheck</span>
        <span class="mt-1 block text-sm text-gray-500 dark:text-gray-400">
          Suit la disponibilité de l'URL de production et peut remonter un état `offline`.
        </span>
      </span>
    </label>

    <label class="flex items-start gap-3 rounded-lg border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-950/60 px-4 py-4">
      <%= form.check_box :cron_monitoring_enabled,
      class: "mt-1 h-4 w-4 rounded border-gray-300 text-cyan-600 focus:ring-cyan-500" %>
      <span class="block">
        <span class="block font-semibold text-gray-900 dark:text-gray-100">Cron monitoring</span>
        <span class="mt-1 block text-sm text-gray-500 dark:text-gray-400">
          Attend un `status.sh` ou un JSON d'état pour les jobs planifiés du projet.
        </span>
      </span>
    </label>

    <div class="flex flex-wrap items-center justify-between gap-3 border-t border-gray-200 dark:border-gray-800 pt-4">
      <p class="text-xs text-gray-500 dark:text-gray-400">
        Runtime: <span class="font-semibold text-gray-700 dark:text-gray-200"><%= project.runtime_monitoring_enabled_label %></span>
        ·
        Cron: <span class="font-semibold text-gray-700 dark:text-gray-200"><%= project.cron_monitoring_enabled_label %></span>
      </p>

      <button
        type="submit"
        class="inline-flex cursor-pointer items-center justify-center gap-2 rounded-md bg-cyan-300 px-4 py-2 text-sm font-bold text-gray-950 hover:bg-cyan-200">
        <%= fa_icon(:floppy_disk, class_name: "text-sm") %>
        Save monitoring
      </button>
    </div>
  <% end %>
</section>
